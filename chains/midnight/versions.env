# Midnight chain version pins
# Midnight uses its own Substrate-based node — NOT cardano-node
# This file is here for consistency but Midnight does NOT use Dockerfile.cardano/apexfusion
# Last updated: 2026-05-17
#
# 0.22.5 notes (midnightntwrk/midnight-node@node-0.22.5, stable):
#   - Node-only patch release; no runtime upgrade required.
#   - Adds optional --max-tx-gas-cost / MAX_TX_GAS_COST tx-pool filter (non-breaking, defaults unbounded).
#   - cNight observation perf: caches multi_asset.id + id-range prefilter → materially less db-sync load.
#   - Devnet bundled chain spec reset to runtime 0.22.0 (we run preview — no impact).
#   - Drop-in upgrade: pull image + restart, no DB resync.

# Midnight node is a pre-built image from midnightntwrk
MIDNIGHT_NODE_IMAGE=midnightntwrk/midnight-node
MIDNIGHT_NODE_VERSION=0.22.5

# Midnight does NOT use:
# - cardano-node (uses Substrate)
# - Guild Operators scripts
# - Mithril
# - CNCLI
# Midnight deployment is handled via its own K3s manifests in chains/midnight/k3s/
