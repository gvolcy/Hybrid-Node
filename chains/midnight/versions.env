for hybrid# Midnight chain version pins
# Midnight uses its own Substrate-based node — NOT cardano-node
# This file is here for consistency but Midnight does NOT use Dockerfile.cardano/apexfusion
# Last updated: 2026-05-31
#
# 1.0.0 GA notes (midnightntwrk/midnight-node@node-1.0.0, released 2026-05-20):
#   - Promotes the 1.0.0-rc.8 tree to the mainnet GA tag (same tree hash, re-cut at
#     final tag). spec_version 1_000_000 / tx_version 3 were already on rc.8, so
#     rc.8 → 1.0.0 is a plain tag bump, NOT a new runtime upgrade.
#   - TransactionExtension replaces deprecated SignedExtension; live signers unaffected
#     (polkadot.js / subxt fetch spec/tx_version from chain on every sign). Only
#     pre-signed extrinsics held across the upgrade boundary need re-signing.
#   - Aligns with polkadot-stable2603 Substrate SDK.
#   - Adds rpc.discover (OpenRPC v1.4) endpoint.
#   - 13 new Prometheus sub-query timers: midnight_data_source_query_time_elapsed{query_name=...}
#   - Cardano-to-Midnight bridge handler hooks landed (bridge NOT enabled — preparatory only).
#   - networkId is validated on boot against chainspec — verify CFG_PRESET matches.
#   - Upgrade procedure: pull image → restart node.
#
# Newer pre-release available (NOT pinned): node-1.0.1-rc.1 (2026-05-29) — makes the
#   unsafe_allow_symlinks config field optional (#serde default false); no runtime,
#   consensus, or ledger changes. Staying on stable 1.0.0 until 1.0.1 GA is cut.

# Midnight node is a pre-built image from midnightntwrk
MIDNIGHT_NODE_IMAGE=midnightntwrk/midnight-node
MIDNIGHT_NODE_VERSION=1.0.0

# Midnight does NOT use:
# - cardano-node (uses Substrate)
# - Guild Operators scripts
# - Mithril
# - CNCLI
# Midnight deployment is handled via its own K3s manifests in chains/midnight/k3s/
