# ApexFusion chain version pins
# ApexFusion Prime uses the same cardano-node binary but with different genesis/config
# IMPORTANT: ApexFusion has NOT validated node versions beyond what's listed here
# Check Scitz0/guild-operators-apex and Apex-Fusion/prime-docker before bumping
# Last updated: 2026-04-05

NODE_VERSION=10.1.4
CLI_VERSION=9.4.1.0
GHC_VERSION=9.6.6
CABAL_VERSION=3.12.1.0
HASKELL_IMAGE_TAG=9.6.6-3.12.1.0-3

# Mithril: NOT AVAILABLE for ApexFusion networks
# mithril-client and mithril-signer are still included in the image for
# compatibility but mithril bootstrap is skipped at runtime for afpm/afpt
MITHRIL_RELEASE=2603.1
MITHRIL_CLIENT_VERSION=0.12.38
MITHRIL_SIGNER_VERSION=0.3.7
MITHRIL_BUILD_HASH=567a8e8

# Companion tools
CNCLI_VERSION=6.7.0
NVIEW_VERSION=0.13.0
TXTOP_VERSION=0.14.0

# Guild Operators source — ApexFusion fork
G_ACCOUNT=Scitz0
GUILD_REPO=guild-operators-apex
GUILD_DEPLOY_BRANCH=main
