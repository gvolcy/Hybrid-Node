# Leios (Ouroboros Leios) chain version pins — Musashi Dojo public testnet
# Musashi Dojo is the public Cardano testnet for Ouroboros Leios (network magic 164),
# running from late June 2026 through the Leios mainnet hard fork.
# https://www.musashi.network/  |  https://leios.cardano-scaling.org/  |  CIP-0164
#
# IMPORTANT: Leios runs a PROTOTYPE cardano-node, NOT a tagged release.
# The node is built from the `leios-prototype` branch, which pulls patched
# ouroboros-consensus and ouroboros-network (also on `leios-prototype`) via
# source-repository-packages pinned in its cabal.project.
#   https://github.com/IntersectMBO/cardano-node/tree/leios-prototype
#   https://github.com/IntersectMBO/ouroboros-consensus/tree/leios-prototype
#   https://github.com/IntersectMBO/ouroboros-network/tree/leios-prototype
# Last updated: 2026-07-24 (prototype-2026w30)

# Release: prototype-2026w30 (ouroboros-leios tag; node reports "11.1.0-leios-prototype").
# REQUIRES RESPIN per the release notes: the musashi testnet contains a block
# that was triggering a ledger issue (ledger#5937 / consensus#2140 — "Stop
# mangling some Dijkstra blocks", the WrongBlockBodySizeBBODY / InvalidBodyHash
# wall we got stuck on at slot 1657690). Wipe local state and sideload from the
# IOG relays or sync from genesis with this release.
# Also adds optional BLS key registration on stake pool certs (StakePoolParams
# gains an optional LeiosKey / ledger#5940) — NO wire-format break, existing
# pool registrations remain valid, and it is not utilized yet, so re-registering
# VOLCY/SILEM with --bls-signing-key-file is not required to rejoin.
# https://github.com/input-output-hk/ouroboros-leios/releases/tag/prototype-2026w30
# NODE_BUILD_REF is the cardano-node commit pinned by the w30 flake.lock (input
# "cardano-node-leios", tip of leios-prototype); ouroboros-consensus bumped to
# e790deca75b4f72e57a1e36c2775bf4111220450 (per cardano-node's cabal.project SRP).
NODE_BUILD_REF=7002fd09162b438b963536b960c6cd42bef022a3
NODE_VERSION_LABEL=11.1.0-leios-prototype
CLI_VERSION=leios-prototype
GHC_VERSION=9.6.7
CABAL_VERSION=3.12.1.0
HASKELL_IMAGE_TAG=9.6.7-3.12.1.0-3

# Network parameters
NETWORK_MAGIC=164
BOOTSTRAP_PEER=leios-node.play.dev.cardano.org:3001

# Config source: Cardano Operations Book (Musashi / Leios pre-environment)
# https://book.play.dev.cardano.org/adv-musashi.html
CONFIG_BASE_URL=https://book.play.dev.cardano.org/environments-pre/leios

# Mithril: NOT available for the Leios testnet (sync from the bootstrap peer)

# tx-firehose: N2C push-based load generator (cardano-node#6613, ch1bo/tx-firehose).
# As of 2026-07-17 this pin has DIVERGED from NODE_BUILD_REF (13 ahead / 5 behind);
# do not assume a firehose rebuild against w29 will work without rebasing #6613.
# Verify with `git merge-base --is-ancestor` / compare before bumping either pin.
# https://github.com/IntersectMBO/cardano-node/pull/6613
# Last verified: 2026-07-17
TX_FIREHOSE_REF=7a345cd726f74797542451cf587554e880dda4ea

# Companion tools (generic Guild Operators tooling)
CNCLI_VERSION=6.7.0
NVIEW_VERSION=0.14.0
TXTOP_VERSION=0.15.0

# Guild Operators source. `leios` branch (added late June 2026) has native
# Musashi (magic 164) support: Dijkstra-era pool-state field names in
# cntools.sh/env (spsMetadata/spsPledge/spsMargin/spsCost/spsRelays/
# spsOwners/spsAccountId, replacing Conway's flat .metadata/.pledge/etc —
# CNTools pool-info display was broken against our Dijkstra-era pools
# without this), NETWORK_NAME=Musashi for magic 164, native musashi network
# defs in guild-deploy.sh (files/configs/musashi/*), and CIP-6 extended pool
# metadata cap raised 512->1024 bytes. Verified 2026-07-14: `leios` is a
# strict superset of `master` (0 behind / 7 ahead) — nothing lost by pinning
# it. https://github.com/cardano-community/guild-operators/tree/leios
# NOTE: this value is documentation only — the Dockerfile.leios ARG default
# is authoritative since CI does not currently pass it as a build-arg.
G_ACCOUNT=cardano-community
GUILD_REPO=guild-operators
GUILD_DEPLOY_BRANCH=leios
