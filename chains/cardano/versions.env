# Cardano chain version pins
# These are the upstream versions validated for Cardano mainnet/preprod/preview/guild
# Update these when IOG releases new versions and you've tested them
# Last updated: 2026-05-05
#
# Node 11.0.1 notes (IntersectMBO/cardano-node@11.0.1, prerelease):
#   - First release supporting the PV11 intra-era hard fork (governance vote required to enact).
#   - Advances experimental hard fork target to PV12.
#   - Adds HTTPS for EKG / Prometheus in cardano-tracer + cardano-rpc REST timeseries store.
#   - No chain replay required (LedgerDB V2 replay was already done in 10.7.0).
#   - Known issues only affect the LSM storage backend (V2LSM); we use the default backend.
#   - Build deps unchanged (liburing-dev / libsnappy-dev / protobuf-compiler — already present).
NODE_VERSION=11.0.1
CLI_VERSION=11.0.0.0
GHC_VERSION=9.6.7
CABAL_VERSION=3.12.1.0
HASKELL_IMAGE_TAG=9.6.7-3.12.1.0-3

# Mithril (Cardano-only — not used by ApexFusion)
# Distribution 2617.0 — mithril-signer reached stable 1.0.0 (production-ready on release-mainnet)
MITHRIL_RELEASE=2617.0
MITHRIL_CLIENT_VERSION=0.13.9
MITHRIL_SIGNER_VERSION=1.0.0
MITHRIL_BUILD_HASH=2478748

# Companion tools
CNCLI_VERSION=6.7.0
NVIEW_VERSION=0.13.0
TXTOP_VERSION=0.15.0
CARDANO_SIGNER_VERSION=1.35.0

# Guild Operators source
G_ACCOUNT=cardano-community
GUILD_REPO=guild-operators
GUILD_DEPLOY_BRANCH=master
